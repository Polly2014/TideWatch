# TideWatch Configuration
# ========================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# LLM 配置 (用于叙事式分析报告生成)
# 通过 CopilotX 代理或直接连接
# LLM_API_BASE=https://api.polly.wang/v1
# LLM_API_KEY=your-key-here
# LLM_MODEL=deepseek-chat

# 数据源配置
# 默认使用 AKShare (免费，无需配置)
# 后续可添加雪球等数据源
# XUEQIU_COOKIE=your-xueqiu-cookie
